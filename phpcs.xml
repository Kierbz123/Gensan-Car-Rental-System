<?xml version="1.0"?>
<ruleset name="IATPS">
    <description>PHP CodeSniffer config — vendor excluded</description>

    <!-- Exclude vendor entirely -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/vendor/**</exclude-pattern>

    <!-- Only scan project source files -->
    <file>classes/</file>
    <file>modules/</file>
    <file>includes/</file>
    <file>config/</file>
    <file>api/</file>
</ruleset>
