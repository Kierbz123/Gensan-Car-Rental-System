# Gensan Car Rental System — Environment Configuration
# Copy this file to .env and customize values for your environment.
# NEVER commit the actual .env file to version control.

# Database
DB_HOST=localhost
DB_NAME=gensan_car_rental_db
DB_USER=gcr_user
DB_PASS=StrongPass123!
DB_CHARSET=utf8mb4

# Encryption (generate a strong random 32-char key for production)
ENCRYPTION_KEY=CHANGE_ME_to_a_random_32char_key!

# SMTP (fill in for production email support)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@gensancarrental.com
SMTP_FROM_NAME=Gensan Car Rental Services
